# ── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=visitor_admin
# Change POSTGRES_PASSWORD before deploying. Never use the default in production.
POSTGRES_PASSWORD=change_me_before_deploy
POSTGRES_DB=visitor_management
DATABASE_URL=postgresql://visitor_admin:change_me_before_deploy@postgres:5432/visitor_management

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379
DELIVERY_EVENTS_CHANNEL=delivery-events

# ── API ──────────────────────────────────────────────────────────────────────
API_PORT=4001
# Comma-separated list of allowed CORS origins.
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# ── Frontend (baked in at Vite build time) ───────────────────────────────────
VITE_API_BASE_URL=http://localhost:4001
VITE_SOCKET_URL=http://localhost:4001
